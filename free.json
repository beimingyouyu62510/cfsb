{
  "log": {
    "level": "warn"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db"
    }
  },
  "dns": {
    "strategy": "ipv4_only",
    "servers": [
      {
        "tag": "fakeip",
        "address": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "cf",
        "address": "https://cloudflare-dns.com/dns-query",
        "detour": "direct"
      },
      {
        "tag": "ali",
        "address": "https://dns.alidns.com/dns-query",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "rule_set": ["ads"],
        "server": "fakeip"
      }
    ],
    "final": "cf"
  },
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "auto",
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ]
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 50,
      "lazy": true
    },
    // 你的 vless 节点部分（保持原样，省略重复粘贴）
    // { "type": "vless", "tag": "new-git", ... },
    // ... 其他节点
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "ads",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      }
      // 可选加 CN bypass
      // {
      //   "tag": "geosite-cn",
      //   "type": "remote",
      //   "format": "binary",
      //   "url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-cn.srs",
      //   "download_detour": "direct",
      //   "update_interval": "24h"
      // },
      // {
      //   "tag": "geoip-cn",
      //   "type": "remote",
      //   "format": "binary",
      //   "url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geoip@rule-set/geoip-cn.srs",
      //   "download_detour": "direct",
      //   "update_interval": "24h"
      // }
    ],
    "rules": [
      {
        "rule_set": ["ads"],
        "outbound": "block"
      }
      // 可选加 CN 直连（防国内走 proxy 慢）
      // {
      //   "rule_set": ["geosite-cn", "geoip-cn"],
      //   "outbound": "direct"
      // },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "final": "proxy"
  }
}
