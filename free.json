        }
      },

      "transport": {
        "type": "ws",
        "path": "/",
        "headers": {
          "Host": "new.jisucf.cloudns.ch"
        }
      },

      "multiplex": {
        "enabled": true
      }
    },



    {
      "type": "vless",
      "tag": "TS-git",
      "server": "104.17.98.5",
      "server_port": 443,
      "uuid": "aa6afb24-210c-4fdc-979e-58f71a6f779f",

      "tls": {
        "enabled": true,
        "server_name": "git01.jisucf.cloudns.biz",
