{
  "log": {
    "level": "warn"
  },
  "dns": {
    "strategy": "ipv4_only",
    "servers": [
      {
        "tag": "fakeip",
        "address": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "cf",
        "address": "https://cloudflare-dns.com/dns-query",
        "detour": "direct"
      },
      {
        "tag": "ali",
        "address": "https://dns.alidns.com/dns-query",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "rule_set": ["ads"],
        "server": "fakeip"
      }
    ],
    "final": "cf"   // 默认用 Cloudflare DoH，更干净
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": true,
      "strict_route": true,
      "auto_redirect": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "auto",
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ]
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 50,
      "lazy": true
    },
    // 你的节点保持不变（略去重复，复制原节点部分即可）
    {
      "type": "vless",
      "tag": "new-git",
      // ... 你的原配置
    },
    // ... 其他节点同上
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "ads",
        "type": "remote",
        "format": "binary",  // 建议转成 .srs 后用 binary
        "url": "https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Filters/AWAvenue-Ads-Rule-Clash.yaml",  // 或转 srs
        "download_detour": "proxy",
        "update_interval": "24h"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-cn.srs",
        "download_detour": "proxy",
        "update_interval": "24h"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-cn.srs",
        "download_detour": "proxy",
        "update_interval": "24h"
      }
    ],
    "rules": [
      {
        "rule_set": ["ads"],
        "outbound": "block"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": ["geosite-cn", "geoip-cn"],
        "outbound": "direct"
      }
    ],
    "final": "proxy"
  }
}
