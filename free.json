        }
      },

      "transport": {
        "type": "ws",
        "path": "/",
        "headers": {
          "Host": "ts02.3xxx.de5.net"
        }
      },

      "multiplex": {
        "enabled": true
      }
    },



    {
      "type": "direct",
      "tag": "direct"
    },

    {
      "type": "block",
      "tag": "block"
    }

  ],



  "route": {

    "auto_detect_interface": true,

    "rule_set": [
      {
        "tag": "ads",
        "type": "remote",
        "format": "yaml",
        "url": "https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Filters/AWAvenue-Ads-Rule-Clash.yaml",
        "download_detour": "proxy",
        "update_interval": "24h"
      }
    ],

    "rules": [

      {
        "rule_set": "ads",
        "outbound": "block"
      },

      {
        "geosite": "cn",
        "outbound": "direct"
      },

      {
        "geoip": "cn",
        "outbound": "direct"
      },

      {
        "geosite": [
          "google",
          "github",
          "openai"
        ],
        "outbound": "proxy"
      }

    ],

    "final": "proxy"
  }
