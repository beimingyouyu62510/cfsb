{
  "log": {
    "level": "warn"
  },

  "dns": {

    "strategy": "ipv4_only",

    "servers": [

      {
        "tag": "fakeip",
        "address": "fakeip"
      },

      {
        "tag": "ali",
        "address": "https://dns.alidns.com/dns-query",
        "detour": "direct"
      },

      {
        "tag": "cf",
        "address": "https://cloudflare-dns.com/dns-query",
        "detour": "proxy"
      }

    ],

    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15"
    },

    "rules": [

      {
        "geosite": "cn",
        "server": "ali"
      },

      {
        "rule_set": "ads",
        "server": "fakeip"
      },

      {
        "geosite": [
          "google",
          "github",
          "openai"
        ],
        "server": "cf"
      }

    ]
  },



  "inbounds": [

    {
      "type": "tun",
      "tag": "tun-in",

      "inet4_address": "172.19.0.1/30",

      "mtu": 9000,

      "auto_route": true,
      "strict_route": true,

      "sniff": true,
      "sniff_override_destination": true
    }

  ],



  "outbounds": [

    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "auto",
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ]
    },



    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "new-git",
        "new-git-clone",
        "TS-git",
        "TS-cf",
        "TS-cf-clone"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m"
    },



    {
      "type": "vless",
      "tag": "new-git",
      "server": "xzus.cf01.dpdns.org",
      "server_port": 443,
      "uuid": "5fbbf263-0518-446c-8ef2-13b2001aa69d",

      "tls": {
        "enabled": true,
        "server_name": "new.jisucf.cloudns.ch",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },

      "transport": {
        "type": "ws",
        "path": "/",
        "headers": {
          "Host": "new.jisucf.cloudns.ch"
        }
      },

      "multiplex": {
        "enabled": true
      }
    },



    {
      "type": "vless",
